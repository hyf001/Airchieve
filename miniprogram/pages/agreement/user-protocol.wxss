.agreement-page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 32rpx;
}

.agreement-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
}

.agreement-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
  margin-bottom: 48rpx;
}

.agreement-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  white-space: pre-line;
}
