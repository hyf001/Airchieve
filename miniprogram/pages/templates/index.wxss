.templates-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.templates-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.templates-empty-icon {
  font-size: 96rpx;
  margin-bottom: 8rpx;
}

.templates-empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
}

.templates-empty-subtitle {
  font-size: 26rpx;
  color: var(--color-text-muted);
}
