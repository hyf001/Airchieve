.home-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* ── Header ── */
.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.home-header-left { display: flex; flex-direction: column; }

.home-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.home-greeting {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.home-points-badge {
  background: var(--color-primary-light);
  border-radius: 32rpx;
  padding: 8rpx 20rpx;
}

.home-points-text { font-size: 22rpx; color: var(--color-primary); font-weight: 600; }

/* ── Create Card ── */
.home-create-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
  margin-bottom: 36rpx;
}

.home-create-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.home-create-icon { font-size: 36rpx; }

.home-create-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
}

.home-settings-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #f1f5f9;
  border-radius: 20rpx;
}

.home-settings-btn-text { font-size: 22rpx; color: var(--color-text-secondary); }
.home-settings-arrow { font-size: 18rpx; color: var(--color-text-muted); }

/* Textarea */
.home-textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f8fafc;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.7;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.home-textarea-placeholder { color: var(--color-text-muted); }

.home-textarea-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* ── Images strip ── */
.home-images-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.home-image-thumb-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
}

.home-image-thumb { width: 100%; height: 100%; display: block; }

.home-image-remove {
  position: absolute;
  top: 0; right: 0;
  width: 32rpx; height: 32rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 0 0 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-image-remove-text { font-size: 24rpx; color: #fff; line-height: 1; }

.home-image-add-btn {
  width: 96rpx; height: 96rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-image-add-icon { font-size: 40rpx; color: var(--color-text-muted); }

/* ── Settings panel ── */
.home-settings-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.home-param-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.home-param-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  width: 80rpx;
  flex-shrink: 0;
}

.home-param-options { display: flex; gap: 12rpx; flex-wrap: wrap; }

.home-param-opt {
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  background: #ffffff;
  border: 2rpx solid var(--color-border);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.home-param-opt--active {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 600;
}

/* ── Action row ── */
.home-action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.home-upload-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 24rpx;
  height: 80rpx;
  background: #f1f5f9;
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  flex-shrink: 0;
}

.home-upload-icon { font-size: 28rpx; }
.home-upload-text { font-size: 24rpx; color: var(--color-text-secondary); }

.home-create-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(14,165,233,0.30);
}

.home-create-btn--loading { opacity: 0.7; }

.home-create-btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ── Section ── */
.home-section { margin-bottom: 40rpx; }

.home-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
  display: block;
}

.home-section-loading,
.home-section-empty {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-section-loading-text,
.home-section-empty-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ── Templates ── */
.home-templates-scroll {
  white-space: nowrap;
  width: 100%;
}

.home-template-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 160rpx;
  padding: 24rpx 16rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  margin-right: 16rpx;
  position: relative;
  vertical-align: top;
}

.home-template-card--selected {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.home-template-icon { font-size: 40rpx; }

.home-template-img {
  width: 128rpx;
  height: 96rpx;
  border-radius: var(--radius-sm);
  display: block;
}

.home-template-name {
  font-size: 22rpx;
  color: var(--color-text);
  text-align: center;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  white-space: normal;
}

.home-template-check {
  position: absolute;
  top: 8rpx; right: 8rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 700;
}

/* ── Public books grid ── */
.home-public-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.home-public-card {
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
}

.home-public-cover {
  width: 100%;
  aspect-ratio: 16 / 9;
  display: block;
}

.home-public-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text);
  padding: 12rpx 16rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
